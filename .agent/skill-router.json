{
  "version": 3,
  "updatedAt": "2026-07-16",
  "sourcePriority": [
    "local-file-evidence",
    "command-output",
    "official-docs-or-primary-sources",
    "local-skill-docs",
    "model-reasoning-labelled-as-assumption"
  ],
  "antigravity": {
    "note": "Antigravity is one supported runtime. This repo keeps canonical agent files inside .agent for portability across tools.",
    "exportRulesPathIfNeeded": ".agents/rules",
    "exportSkillsPathIfNeeded": ".agents/skills",
    "canonicalRulesPathUsedByThisRepo": ".agent/rules",
    "canonicalSkillsPathUsedByThisRepo": ".agent/skills"
  },
  "requiredValidation": {
    "agentConfigChanged": [
      "node .agent/scripts/bootstrap-agent.mjs",
      "node .agent/scripts/validate-agent-skills.mjs",
      "node .agent/scripts/agent-doctor.mjs",
      "node .agent/scripts/deep-skill-audit.mjs",
      "node .agent/scripts/audit-skill-quality.mjs",
      "node .agent/scripts/self-review-validator.mjs --scope agent",
      "node .agent/scripts/export-agent-adapters.mjs --dry-run"
    ],
    "stackUnknown": [
      "node .agent/scripts/detect-project.mjs"
    ]
  },
  "activeSkillSet": ".agent/active-skills.json",
  "projectInventory": ".agent/projects/index.json",
  "onDemandBundleMechanism": {
    "source": ".agent/active-skills.json -> onDemandBundles",
    "rule": "Sebagian skill disimpan sebagai bundle yang belum diinstall (mis. wordpress, mobile). Kalau request user cocok dengan onDemandBundles.bundles[].wireInto.routeWhen, agent WAJIB menjalankan 'node .agent/scripts/restore-skill-bundle.mjs <bundle>' lebih dulu (otomatis, beri tahu user singkat), baru lanjut. User tidak perlu hafal command-nya.",
    "restoreScript": "node .agent/scripts/restore-skill-bundle.mjs <bundle>",
    "listBundles": "node .agent/scripts/restore-skill-bundle.mjs"
  },
  "professionalStandards": {
    "security": "OWASP ASVS-style verification for web application security controls.",
    "accessibility": "WCAG 2.2 for user-facing web UI.",
    "supplyChain": "SLSA-style supply-chain integrity: lockfiles, reproducible commands, no secrets.",
    "definitionOfDone": [
      "files changed are named",
      "evidence inspected is named",
      "validation command and result are named",
      "remaining risk is stated"
    ]
  },
