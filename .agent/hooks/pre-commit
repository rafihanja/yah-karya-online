#!/usr/bin/env bash
# .agent/hooks/pre-commit
#
# Hard quality gate for SKILL.md commits (Skill Library Revolution standard).
# Runs enforce-skill-quality.mjs against staged SKILL.md files.
# Aborts commit if any file violates the 4 quality rules or required markers.
#
# Activation (one-time per clone):
#   git config core.hooksPath .agent/hooks
#
# Bypass (use ONLY when explicitly authorized by user):
#   git commit --no-verify

set -e

# Check if any .agent/skills/**/SKILL.md is staged
staged_skill_count=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '^\.agent/skills/.+/SKILL\.md$' || true)

if [ "$staged_skill_count" -eq 0 ]; then
  exit 0
fi

# Locate repo root (script may be invoked from subdirectory)
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Run enforce script in --staged mode
if ! node .agent/scripts/enforce-skill-quality.mjs --staged; then
  echo ""
  echo "════════════════════════════════════════════════════════════════════"
  echo "  COMMIT BLOCKED by .agent/hooks/pre-commit"
  echo ""
  echo "  One or more staged SKILL.md files violate quality rules."
  echo "  Fix the violations listed above, re-stage, and commit again."
  echo ""
  echo "  To bypass (ONLY with user authorization):"
  echo "    git commit --no-verify"
  echo "════════════════════════════════════════════════════════════════════"
  exit 1
fi

exit 0
